{
    "name": "honemo/wp-github-updater",
    "description": "A WordPress library to update plugins from GitHub repositories.",
    "config": {
        "allow-plugins": {
            "roots/wordpress-core-installer": true,
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    },
    "autoload": {
        "psr-4": {
            "honemo\\updater\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "honemo\\updater\\Tests\\": "tests/"
        }
    },
    "require-dev": {
        "roots/wordpress": "@stable",
        "squizlabs/php_codesniffer": "^3.7",
        "wp-coding-standards/wpcs": "^3.0",
        "phpcompatibility/phpcompatibility-wp": "^2.1",
        "phpstan/phpstan": "^1.10",
        "szepeviktor/phpstan-wordpress": "^1.3",
        "dealerdirect/phpcodesniffer-composer-installer": "^1.0",
        "yoast/wp-test-utils": "^1.2",
        "phpunit/phpunit": "^9.6",
        "mockery/mockery": "^1.6",
        "brain/monkey": "^2.6"
    },
    "scripts": {
        "phpcs": "vendor/bin/phpcs",
        "phpcs:fix": "vendor/bin/phpcbf",
        "phpstan": "vendor/bin/phpstan analyze --memory-limit=2G",
        "test": "vendor/bin/phpunit",
        "test:coverage": "vendor/bin/phpunit --coverage-html build/coverage",
        "check": [
            "@phpcs",
            "@phpstan"
        ],
        "check:all": [
            "@phpcs",
            "@phpstan",
            "@test"
        ]
    }
    
}
